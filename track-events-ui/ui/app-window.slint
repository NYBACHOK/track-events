import { Button, VerticalBox, ScrollView } from "std-widgets.slint";

struct EventData {
    id : int,
    name: string,
    icon: image,
}

export component App inherits Window {
    width: 450px;
    height: 600px;
    title: "Event Viewer";
    background: #f4f4f9;

    in property <[EventData]> events;
    callback event-clicked(int);
    callback request-events();

   

    ScrollView {
        width: 100%;
        height: 100%;

        GridLayout {
            spacing: 8px;
            padding: 10px;

            // 1. Loop through data
            for event[i] in root.events: VerticalLayout {
                // 2. Set grid position on the container
                row: Math.floor(i / 3);
                col: Math.mod(i, 3);
                
                // 3. Your visual element inside the container
                Rectangle {
                    width: 140px;
                    height: 60px;
                    background: white;
                    border-radius: 8px;
                    drop-shadow-blur: 4px;
                    drop-shadow-color: #00000015;

                    HorizontalLayout {
                        padding: 12px;
                        spacing: 15px;
                        alignment: start;

                        Image {
                            source: event.icon;
                            width: 32px;
                            height: 32px;
                            image-fit: contain;
                            colorize: #4A90E2;
                        }

                        Text {
                            text: event.name;
                            vertical-alignment: center;
                            font-size: 14px;
                            color: #222;
                            overflow: elide;
                        }
                    }

                    states [
                        hover when touch.has-hover: {
                            background: #eee;
                        }
                        pressed when touch.pressed: {
                            background: #e0e0e0;
                        }
                    ]
                    touch := TouchArea {
                        clicked => {
                            root.event-clicked(event.id);
                        }
                    }
                }
            }
        }
    }
}
