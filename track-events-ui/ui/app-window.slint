import { ScrollView, VerticalBox } from "std-widgets.slint";

struct EventData {
    id : int,
    name: string,
    icon: image,
    occurrence_count : int,
}

export component App inherits Window {
    // Set preferred/minimum sizes instead of strict fixed sizes
    min-width: 320px;
    min-height: 400px;
    preferred-width: 500px;
    preferred-height: 600px;
    title: "Event Viewer";
    background: #f4f4f9;

    in property <[EventData]> events;
    callback event-clicked(int);
    callback request-events();
    
    // Dynamic Column Calculation
    // We adjust the columns based on the window width
    private property <int> cols: Math.max(1, Math.floor(root.width / 160px));

    ScrollView {

        GridLayout { 
            padding: 10px;
            spacing: 12px;

            for event[i] in root.events: VerticalLayout {
                row: Math.floor(i / root.cols);
                col: Math.mod(i, root.cols);
                Rectangle {
                    min-height: 64px;
                    background: white;
                    border-radius: 12px; // Slightly rounder for modern look
                    drop-shadow-blur: 6px;
                    drop-shadow-color: #00000010;

                    HorizontalLayout {
                        padding: 12px;
                        spacing: 12px;

                        Image {
                            source: event.icon;
                            width: 32px;
                            height: 32px;
                            image-fit: contain;
                            colorize: #4A90E2;
                        }

                        VerticalLayout {
                            alignment: center;
                            Text {
                                text: event.name;
                                font-size: 14px;
                                font-weight: 600;
                                color: #2d3436;
                                overflow: elide;
                            }

                            Text {
                                text: event.occurrence_count;
                                font-size: 11px;
                                color: #636e72;
                            }
                        }
                    }

                    states [
                        hover when touch.has-hover: {
                            background: #f8f9fa;
                        }
                        pressed when touch.pressed: {
                            background: #e9ecef;
                        }
                    ]
                    touch := TouchArea {
                        clicked => {
                            root.event-clicked(event.id);
                        }
                    }
                }
            }
        }
    }
}
