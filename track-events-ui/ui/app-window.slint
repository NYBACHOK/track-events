import { ScrollView, VerticalBox } from "std-widgets.slint";

import { EventData } from "types.slint";
import { TabItem } from "components/tab_item.slint";
import {
    TrackPage,
    SettingsPage,
    LibraryPage,
    InsightsPage,
} from "pages/pages.slint";
import { AppLogic } from "logic.slint";

import { Icons } from "store.slint";

export { AppLogic }

enum AppPage { Track, Library, Insights, Settings }

export component App inherits Window {
    min-width: 320px;
    min-height: 400px;
    preferred-width: 500px;
    preferred-height: 600px;
    title: "Event Tracker";
    background: #f4f4f9;

    // Navigation State (Default to index 1: Track)
    private property <AppPage> active-tab: AppPage.Track;

    VerticalLayout {
        Rectangle {
            vertical-stretch: 1;
            if (active-tab == AppPage.Library): LibraryPage { }
            if (active-tab == AppPage.Track): TrackPage { }
            if (active-tab == AppPage.Insights): InsightsPage { }
            if (active-tab == AppPage.Settings): SettingsPage { }
        }

        Rectangle {
            height: 65px;
            background: white;
            border-color: #e0e0e0;
            border-width: 1px;

            HorizontalLayout {
                padding-top: 5px;
                padding-bottom: 5px;
                TabItem {
                    text: "Library";
                    icon: Icons.lib-tab;
                    active: active-tab == AppPage.Library;
                    clicked => {
                        active-tab = AppPage.Library;
                    }
                }

                TabItem {
                    text: "Track";
                    icon: Icons.track-tab;
                    active: active-tab == AppPage.Track;
                    clicked => {
                        active-tab = AppPage.Track;
                    }
                }

                TabItem {
                    text: "Insights";
                    icon: Icons.insights-tab;
                    active: active-tab == AppPage.Insights;
                    clicked => {
                        active-tab = AppPage.Insights;
                    }
                }

                TabItem {
                    text: "Settings";
                    icon: Icons.settings-tab;
                    active: active-tab == AppPage.Settings;
                    clicked => {
                        active-tab = AppPage.Settings;
                    }
                }
            }
        }
    }
}
