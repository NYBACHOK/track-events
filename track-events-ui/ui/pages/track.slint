import { ScrollView } from "std-widgets.slint";
import { EventData, EventDataWithChildren } from "../types.slint";
import { AppLogic } from "../logic.slint";
import { Label } from "../components/label.slint";

export component TrackPage inherits Rectangle {
    private property <bool> showing-details <=> AppLogic.showing-details;
    private property <EventDataWithChildren> active-details <=> AppLogic.active-details;

    init => {
        AppLogic.request-events();
    }

    private property <int> cols: Math.max(1, Math.floor(root.width / 160px));

    // --- Main View ---
    if (!showing-details): ScrollView {
        GridLayout {
            padding: 10px;
            spacing: 12px;
            for event[i] in AppLogic.events: VerticalLayout {
                row: Math.floor(i / root.cols);
                col: Math.mod(i, root.cols);
                Rectangle {
                    min-height: 64px;
                    background: white;
                    border-radius: 12px;
                    HorizontalLayout {
                        padding: 12px;
                        spacing: 12px;
                        alignment: center;
                        Image {
                            source: event.svg-icon;
                            width: 32px;
                            height: 32px;
                            image-fit: contain;
                            colorize: #4A90E2;
                        }

                        VerticalLayout {
                            horizontal-stretch: 1;
                            Label {
                                text: event.name;
                                font-size: 14px;
                                font-weight: 600;
                                color: #2d3436;
                                overflow: elide;
                            }

                            if (!event.has-sub-events): Label {
                                text: event.event-occurrence;
                                font-size: 11px;
                                color: #636e72;
                            }
                        }

                        if (event.has-sub-events): Image {
                            source: @image-url("../../icons/chevron-right.svg");
                            width: 16px;
                            colorize: #b2bec3;
                        }
                    }

                    touch := TouchArea {
                        clicked => {
                            if (event.has-sub-events) {
                                AppLogic.event-details(event.id);
                                root.showing-details = true;
                            } else {
                                AppLogic.event-clicked(event.id);
                            }
                        }
                    }
                }
            }
        }
    }

    // --- Sub-Event Detail View ---
    if (showing-details): VerticalLayout {
        padding: 10px;
        spacing: 15px;

        HorizontalLayout {
            Label {
                horizontal-alignment: TextHorizontalAlignment.left;
                text: root.active-details.name;
                font-size: 20px;
                font-weight: 700;
            }

            // Back Button
        HorizontalLayout {
                alignment: end;
                TouchArea {
                    clicked => {
                        root.showing-details = false;
                    }
                    HorizontalLayout {
                        spacing: 5px;
                        Image {
                            source: @image-url("../../icons/arrow-left.svg");
                            width: 16px;
                            colorize: #4A90E2;
                        }

                        Label {
                            text: "Back to Main";
                            color: #4A90E2;
                            font-weight: 400;
                        }
                    }
                }
            }
        }

        ScrollView {
            VerticalLayout {
                spacing: 8px;
                for sub-event in root.active-details.sub-events: Rectangle {
                    height: 50px;
                    background: white;
                    border-radius: 8px;
                    HorizontalLayout {
                        padding: 10px;
                        spacing: 10px;
                        Image {
                            source: sub-event.svg-icon;
                            width: 24px;
                            colorize: #4A90E2;
                        }

                        Label {
                            text: sub-event.name;
                            vertical-alignment: center;
                        }

                        Rectangle { } // Spacer
                        Label {
                            text: sub-event.event-occurrence;
                            vertical-alignment: center;
                            color: #666;
                        }
                    }

                    TouchArea {
                        clicked => {
                            AppLogic.event-clicked(sub-event.id);
                        }
                    }
                }
            }
        }
    }
}
