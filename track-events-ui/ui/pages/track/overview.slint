import { ScrollView } from "std-widgets.slint";
import { EventData, EventDataWithChildren } from "../../types.slint";
import { AppLogic } from "../../logic.slint";
import { Label } from "../../components/label.slint";

import { Icons } from "../../store.slint";
import { Badge } from "../../components/badge.slint";
import { Theme } from "../../theme.slint";

export component OverviewComponent inherits ScrollView {
    in-out property <int> cols;
    in-out property <bool> showing-details;

    GridLayout {
        padding: Theme.padding;
        spacing: 12px;
        for event[i] in AppLogic.events: VerticalLayout {
            row: Math.floor(i / root.cols);
            col: Math.mod(i, root.cols);
            event_cell := Rectangle {
                min-height: 64px;
                background: white;
                border-radius: 12px;
                HorizontalLayout {
                    padding: Theme.padding;
                    spacing: 12px;
                    alignment: center;
                    Image {
                        source: event.svg-icon;
                        width: 32px;
                        height: 32px;
                        image-fit: contain;
                        colorize: #4A90E2;
                    }
                        Label {
                            text: event.name;
                            font-size: 14px;
                            font-weight: 600;
                            color: #2d3436;
                            overflow: TextOverflow.clip;
                        }

                        if (!event.has-sub-events): Badge {
                            text: event.event-occurrence;
                            font-size: 11px;
                            target-component-width <=> event_cell.width;
                            target-component-height <=> event_cell.height;
                          
                        }
                

                    if (event.has-sub-events): Image {
                        source: Icons.chevron-right;
                        width: 16px;
                        colorize: #b2bec3;
                    }
                }

                touch := TouchArea {
                    clicked => {
                        if (event.has-sub-events) {
                            AppLogic.event-details(event.id);
                            root.showing-details = true;
                        } else {
                            AppLogic.event-clicked(event.id);
                        }
                    }
                }
            }
        }
    }
}
